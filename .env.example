# Database (Neon PostgreSQL)
#
# Dev and prod MUST point at different Neon branches. See docs/architecture/DEPLOYMENT.md.
#
# - .env              → dev Neon branch (local development)
# - .env.production   → prod Neon branch (reference copy; source of truth is Vercel env vars)
#
# Both URLs are required because prisma/schema.prisma declares `directUrl`:
#   DATABASE_URL         → pooled connection (pgbouncer=true&connection_limit=<N>)
#   DIRECT_DATABASE_URL  → direct connection (used by `prisma migrate`)
#
# connection_limit differs by runtime (see DEPLOYMENT.md):
#   Local dev       → connection_limit=5 (long-lived Node process)
#   Vercel (prod/preview) → connection_limit=1 (serverless; per-instance cap)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?pgbouncer=true&connection_limit=5&sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudflare R2 (card images — used by pipeline/migrate-images.ts and production image serving)
# R2 endpoint: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# CDN URL: public bucket URL or custom domain (e.g. https://images.optcgsim.com)
# Free tier: 10GB storage, 10M Class-A ops/month, 1M Class-B ops/month
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="optcg-images"
NEXT_PUBLIC_CDN_URL="https://pub-<your-bucket-id>.r2.dev"  # or custom domain

# Upstash Redis (distributed rate limiting)
# Create a free database at https://console.upstash.com
# Falls back to in-memory rate limiting when not set (local dev only)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Game Worker (M3)
# Production URL: https://optcg-game.<your-subdomain>.workers.dev
# Local dev URL: http://localhost:8787 (wrangler dev)
GAME_WORKER_URL="http://localhost:8787"
NEXT_PUBLIC_GAME_WORKER_URL="http://localhost:8787"
# Shared secret between Next.js and the Cloudflare Worker — generate with: openssl rand -hex 32
# Must also be set in workers/game/.dev.vars (local) and `wrangler secret put` (production)
GAME_WORKER_SECRET=""
