# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/optcg_sim?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudflare R2 (card images — used by pipeline/migrate-images.ts and production image serving)
# R2 endpoint: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# CDN URL: public bucket URL or custom domain (e.g. https://images.optcgsim.com)
# Free tier: 10GB storage, 10M Class-A ops/month, 1M Class-B ops/month
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="optcg-images"
NEXT_PUBLIC_CDN_URL="https://pub-<your-bucket-id>.r2.dev"  # or custom domain

# Cloudflare Game Worker (M3)
# Production URL: https://optcg-game.<your-subdomain>.workers.dev
# Local dev URL: http://localhost:8787 (wrangler dev)
GAME_WORKER_URL="http://localhost:8787"
NEXT_PUBLIC_GAME_WORKER_URL="http://localhost:8787"
# Shared secret between Next.js and the Cloudflare Worker — generate with: openssl rand -hex 32
# Must also be set in workers/game/.dev.vars (local) and `wrangler secret put` (production)
GAME_WORKER_SECRET=""
